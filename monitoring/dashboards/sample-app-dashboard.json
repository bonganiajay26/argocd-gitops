{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Sample App — GitOps Platform Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 1 },
            { "color": "green", "value": 3 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Ready Pods (prod)",
      "type": "stat",
      "targets": [{
        "expr": "kube_deployment_status_replicas_ready{deployment=\"sample-app\",namespace=\"prod\"}",
        "legendFormat": "ready"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 2,
      "title": "CPU Usage by Namespace",
      "type": "timeseries",
      "targets": [{
        "expr": "rate(container_cpu_usage_seconds_total{container=\"sample-app\",namespace=~\"dev|staging|prod\"}[5m])",
        "legendFormat": "{{ namespace }}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 3,
      "title": "Memory Usage by Namespace",
      "type": "timeseries",
      "targets": [{
        "expr": "container_memory_working_set_bytes{container=\"sample-app\",namespace=~\"dev|staging|prod\"}",
        "legendFormat": "{{ namespace }}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 4,
      "title": "Request Rate",
      "type": "timeseries",
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"sample-app\"}[5m])) by (namespace, status)",
        "legendFormat": "{{ namespace }} - {{ status }}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 5,
      "title": "Latency P50/P95/P99",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"sample-app\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"sample-app\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"sample-app\"}[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "id": 6,
      "title": "Restart Count (crash-loop detection)",
      "type": "timeseries",
      "targets": [{
        "expr": "rate(kube_pod_container_status_restarts_total{container=\"sample-app\"}[15m]) * 60",
        "legendFormat": "{{ namespace }}/{{ pod }}"
      }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["gitops", "sample-app", "kubernetes"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Sample App — GitOps Platform",
  "uid": "sample-app-gitops",
  "version": 1
}
